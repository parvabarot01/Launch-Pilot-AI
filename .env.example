# Copy this file to .env.local and fill in values when you're ready to connect
# real services. Every one of these is OPTIONAL: LaunchPilot runs fully
# standalone on a local file-based store with no values set at all.
#
# Nothing in this app calls out to a third party unless the matching
# variable below is present. See ARCHITECTURE.md "Service Adapters" for
# exactly where each swap point lives in the code.

# --- Session / auth ---
# Secret used to sign session cookies. Required in production; a dev
# default is used automatically when this is unset.
SESSION_SECRET=

# --- Supabase (Postgres + Auth) ---
# When set, lib/db swaps the local JSON store for Supabase Postgres.
# Leave unset to keep using the local store.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Upstash Redis (flag-eval cache + rate limiting) ---
# When set, lib/cache and lib/ratelimit swap the in-memory implementations
# for Upstash Redis. Leave unset to keep using in-memory versions (fine for
# a single dev/demo instance, not for multi-instance production).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Groq (AI Decision Assistant) ---
# When set, lib/ai calls the Groq API (Llama 3.3 70B) grounded in the org's
# real flag/experiment data. Leave unset to keep using the built-in
# rule-based statistical heuristics engine (no external call, always available).
GROQ_API_KEY=
